<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — Sistema de Prácticas</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --sidebar-bg: #0f1623;
    --sidebar-w: 222px;
    --accent: #7c5cfc;
    --accent-light: rgba(124,92,252,0.1);
    --bg: #f4f6fb;
    --surface: #ffffff;
    --border: #e8ecf4;
    --text: #1a1f36;
    --muted: #8a94ad;
    --success: #22c55e;
    --warning: #f59e0b;
    --danger: #ef4444;
    --info: #3b82f6;
  }

  body.dark {
    --bg: #0b0f1a;
    --surface: #111827;
    --border: #1e293b;
    --text: #f1f5f9;
    --muted: #64748b;
  }

  /* Actividades */
  body.dark .activity-item {
    background: #1a2234;
    border-color: #1e293b;
  }

  body.dark .activity-title,
  body.dark .activity-sub {
    color: #f1f5f9;
  }

  /* Tabla - header */
  body.dark thead {
    background: #1a2234;
  }

  body.dark th {
    color: #64748b;
  }

  /* Tabla - hover de filas */
  body.dark tr:hover td {
    background: #1a2234;
  }

  /* Tabla - fondo de filas */
  body.dark td {
    color: #f1f5f9;
  }

  /* Search input en oscuro */
  body.dark .search-box input {
    background: #111827;
    color: #f1f5f9;
    border-color: #1e293b;
  }

  /* Cards de charts */
  body.dark .card {
    background: #111827;
    border-color: #1e293b;
  }

  /* Topbar */
  body.dark .topbar {
    background: #111827;
    border-color: #1e293b;
  }

  /* Table card */
  body.dark .table-card {
    background: #111827;
    border-color: #1e293b;
  }

  /* Stat cards */
  body.dark .stat-card {
    background: #111827;
    border-color: #1e293b;
  }

    html, body { height: 100%; }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      display: flex;
      min-height: 100vh;
    }

    /* ══════════════ SIDEBAR ══════════════ */
    .sidebar {
      width: var(--sidebar-w);
      min-height: 100vh;
      background: var(--sidebar-bg);
      display: flex;
      flex-direction: column;
      position: fixed;
      left: 0; top: 0; bottom: 0;
      z-index: 50;
    }

    .sidebar-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 22px 18px 18px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      margin-bottom: 10px;
    }

    .logo-icon {
      width: 36px; height: 36px;
      background: var(--accent);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; color: #fff; flex-shrink: 0;
    }

    .logo-text { font-size: 13.5px; font-weight: 700; color: #fff; line-height: 1.25; }

    .nav-section { padding: 0 10px; flex: 1; }

    .nav-link {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 12px;
      border-radius: 10px;
      text-decoration: none;
      color: rgba(255,255,255,0.48);
      font-size: 13.5px; font-weight: 500;
      transition: all 0.15s;
      cursor: pointer;
      margin-bottom: 2px;
    }

    .nav-link i { font-size: 16px; width: 18px; text-align: center; }

    .nav-link:hover { color: rgba(255,255,255,0.82); background: rgba(255,255,255,0.06); }
    .nav-link.active { background: var(--accent); color: #fff; }

    .nav-badge {
      margin-left: auto;
      background: var(--accent);
      color: #fff;
      font-size: 10px; font-weight: 700;
      min-width: 18px; height: 18px;
      border-radius: 9px;
      display: flex; align-items: center; justify-content: center;
      padding: 0 5px;
    }

    .nav-link.active .nav-badge { background: rgba(255,255,255,0.22); }

    .sidebar-footer {
      padding: 0 10px 20px;
      border-top: 1px solid rgba(255,255,255,0.06);
      padding-top: 14px;
      margin-top: 8px;
    }

    .sidebar-user {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 10px; border-radius: 10px; cursor: pointer;
    }

    .user-avatar {
      width: 34px; height: 34px; border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), #06b6d4);
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 700; color: #fff; flex-shrink: 0;
    }

    .user-info { flex: 1; min-width: 0; }
    .user-name { font-size: 13px; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .user-role { font-size: 11px; color: rgba(255,255,255,0.38); }
    .user-online { width: 8px; height: 8px; background: var(--success); border-radius: 50%; flex-shrink: 0; }

    /* ══════════════ MAIN ══════════════ */
    .main-wrapper { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; }

    .topbar {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      height: 64px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 30px;
      position: sticky; top: 12px; z-index: 40;
      border-radius: 16px;
      margin: 12px 16px 0;
    }

    .topbar-left h2 { font-size: 19px; font-weight: 700; }
    .topbar-left p { font-size: 13px; color: var(--muted); }

    .topbar-right { display: flex; align-items: center; gap: 12px; }

    .notif-btn {
      position: relative;
      width: 38px; height: 38px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--surface);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; color: var(--muted); font-size: 17px;
      transition: all 0.15s;
    }

    .notif-btn:hover { border-color: var(--accent); color: var(--accent); }

    .notif-dot {
      position: absolute; top: 6px; right: 6px;
      width: 8px; height: 8px;
      background: var(--danger);
      border-radius: 50%; border: 2px solid var(--surface);
    }

    .topbar-user {
      display: flex; align-items: center; gap: 9px;
      padding: 5px 13px 5px 5px;
      border-radius: 50px; border: 1px solid var(--border);
      cursor: pointer; transition: border-color 0.15s;
    }

    .topbar-user:hover { border-color: var(--accent); }

    .topbar-avatar {
      width: 30px; height: 30px; border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), #06b6d4);
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; color: #fff;
    }

    .topbar-info .name { font-size: 13px; font-weight: 600; }
    .topbar-info .role { font-size: 11px; color: var(--muted); }

    .btn-add {
      display: flex; align-items: center; gap: 8px;
      background: var(--accent); color: #fff; border: none;
      border-radius: 10px; padding: 10px 18px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px; font-weight: 600; cursor: pointer;
      transition: all 0.15s;
      box-shadow: 0 4px 14px rgba(124,92,252,0.32);
    }

    .btn-add:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(124,92,252,0.42); }

    /* ══════════════ CONTENT ══════════════ */
    .content { padding: 26px 30px; flex: 1; }

    .welcome-row { margin-bottom: 22px; }
    .welcome-row h1 { font-size: 23px; font-weight: 800; }
    .welcome-row p { font-size: 13.5px; color: var(--muted); margin-top: 3px; }

    /* STAT CARDS */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 22px;
    }

    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 20px 20px;
      display: flex; align-items: center; gap: 14px;
      transition: box-shadow 0.2s, transform 0.2s;
      animation: fadeUp 0.4s ease both;
    }

    .stat-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.07); transform: translateY(-2px); }
    .stat-card:nth-child(1) { animation-delay: .05s; }
    .stat-card:nth-child(2) { animation-delay: .1s; }
    .stat-card:nth-child(3) { animation-delay: .15s; }
    .stat-card:nth-child(4) { animation-delay: .2s; }

    .stat-icon {
      width: 50px; height: 50px; border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 22px; flex-shrink: 0;
    }

    .stat-card:nth-child(1) .stat-icon { background: rgba(124,92,252,0.12); color: #7c5cfc; }
    .stat-card:nth-child(2) .stat-icon { background: rgba(34,197,94,0.12); color: #22c55e; }
    .stat-card:nth-child(3) .stat-icon { background: rgba(245,158,11,0.12); color: #f59e0b; }
    .stat-card:nth-child(4) .stat-icon { background: rgba(59,130,246,0.12); color: #3b82f6; }

    .stat-body { flex: 1; }
    .stat-label { font-size: 12px; color: var(--muted); font-weight: 500; }
    .stat-value { font-size: 28px; font-weight: 800; line-height: 1.1; margin: 2px 0 3px; }

    .stat-card:nth-child(1) .stat-value { color: #7c5cfc; }
    .stat-card:nth-child(2) .stat-value { color: #22c55e; }
    .stat-card:nth-child(3) .stat-value { color: #f59e0b; }
    .stat-card:nth-child(4) .stat-value { color: #3b82f6; }

    .stat-delta { font-size: 12px; font-weight: 500; color: var(--success); }
    .stat-delta.neutral { color: var(--muted); }

    /* CHARTS ROW */
    .charts-row {
      display: grid;
      grid-template-columns: 1fr 2fr 1fr;
      gap: 16px;
      margin-bottom: 22px;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 20px 22px;
      animation: fadeUp 0.45s ease both;
    }

    .card-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 16px;
    }

    .card-title { font-size: 14.5px; font-weight: 700; }

    .card-action {
      font-size: 12px; color: var(--accent); font-weight: 600;
      cursor: pointer; text-decoration: none;
      padding: 4px 10px; border-radius: 8px;
      border: 1px solid rgba(124,92,252,0.2);
      background: var(--accent-light);
      transition: background 0.15s;
    }

    .card-action:hover { background: rgba(124,92,252,0.18); }

    /* DONUT */
    .donut-wrap { display: flex; flex-direction: column; align-items: center; }
    .donut-canvas-wrap { position: relative; width: 150px; height: 150px; margin: 0 auto 14px; }

    .legend-item {
      display: flex; align-items: center; gap: 8px;
      font-size: 11.5px; color: var(--muted); margin-bottom: 6px;
    }

    .legend-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .legend-item span:last-child { margin-left: auto; font-weight: 700; color: var(--text); font-size: 12px; }

    /* SELECT */
    .select-sm {
      font-size: 12px; font-family: 'Plus Jakarta Sans', sans-serif;
      border: 1px solid var(--border); border-radius: 8px;
      padding: 4px 8px; color: var(--muted);
      background: var(--surface); cursor: pointer; outline: none;
    }

    /* ACTIVITIES */
    .activity-list { display: flex; flex-direction: column; gap: 9px; }

    .activity-item {
      display: flex; align-items: flex-start; gap: 11px;
      padding: 10px 12px; border-radius: 12px;
      border: 1px solid var(--border); background: #fafbff;
      transition: background 0.15s;
    }

    .activity-item:hover { background: var(--accent-light); border-color: rgba(124,92,252,0.18); }

    .activity-date {
      display: flex; flex-direction: column; align-items: center;
      min-width: 34px; background: var(--accent); color: #fff;
      border-radius: 8px; padding: 4px 5px;
      font-size: 9.5px; font-weight: 700; text-transform: uppercase; line-height: 1.3;
    }

    .activity-date .day { font-size: 16px; font-weight: 800; }

    .activity-body { flex: 1; }
    .activity-title { font-size: 12.5px; font-weight: 600; line-height: 1.3; }
    .activity-sub { font-size: 11px; color: var(--muted); margin-top: 1px; }

    .activity-badge {
      font-size: 10px; font-weight: 600; padding: 3px 8px;
      border-radius: 20px; flex-shrink: 0; align-self: flex-start;
    }

    .badge-pending { background: rgba(245,158,11,0.12); color: #d97706; }
    .badge-done { background: rgba(34,197,94,0.12); color: #16a34a; }

    /* TABLE */
    .table-section-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 14px;
    }

    .search-box { position: relative; width: 260px; }
    .search-box i { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 13px; }
    .search-box input {
      width: 100%; background: var(--surface); border: 1px solid var(--border);
      border-radius: 10px; padding: 9px 14px 9px 35px;
      color: var(--text); font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13px; outline: none; transition: border-color 0.2s;
    }

    .search-box input:focus { border-color: var(--accent); }
    .search-box input::placeholder { color: var(--muted); }

    .table-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; animation: fadeUp 0.5s ease both; animation-delay: .25s; }

    table { width: 100%; border-collapse: collapse; }
    thead { background: #fafbff; }

    th {
      padding: 12px 16px;
      text-align: left;
      font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.07em;
      color: var(--muted); border-bottom: 1px solid var(--border);
    }

    td {
      padding: 13px 16px; font-size: 13px;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }

    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #fafbff; }

    .name-cell { font-weight: 600; }
    .name-cell small { display: block; color: var(--muted); font-size: 11.5px; font-weight: 400; }

    .dni-cell { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--accent); }

    .nota-badge {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 50px; padding: 4px 10px; border-radius: 8px;
      font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 700;
    }

    .nota-high { background: rgba(34,197,94,0.1); color: #16a34a; }
    .nota-mid  { background: rgba(245,158,11,0.1); color: #d97706; }
    .nota-low  { background: rgba(239,68,68,0.1);  color: #dc2626; }
    .nota-none { background: var(--bg); color: var(--muted); }

    .estado-badge {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 11.5px; font-weight: 600; padding: 4px 10px; border-radius: 20px;
      background: rgba(34,197,94,0.1); color: #16a34a;
    }

    .estado-badge::before { content: ''; width: 6px; height: 6px; background: currentColor; border-radius: 50%; }

    .actions { display: flex; gap: 5px; }

    .btn-icon {
      width: 31px; height: 31px; border-radius: 8px;
      border: 1px solid var(--border); background: transparent;
      color: var(--muted); display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: all 0.15s; font-size: 13px;
    }

    .btn-icon.view:hover { background: rgba(59,130,246,0.1); color: #3b82f6; border-color: rgba(59,130,246,0.28); }
    .btn-icon.edit:hover { background: rgba(245,158,11,0.1); color: #d97706; border-color: rgba(245,158,11,0.28); }
    .btn-icon.del:hover  { background: rgba(239,68,68,0.1); color: #ef4444; border-color: rgba(239,68,68,0.28); }

    .pagination {
      display: flex; align-items: center; justify-content: space-between;
      padding: 13px 16px; border-top: 1px solid var(--border);
      font-size: 12.5px; color: var(--muted);
    }

    .pag-controls { display: flex; gap: 5px; }

    .pag-btn {
      width: 31px; height: 31px; border-radius: 8px;
      border: 1px solid var(--border); background: transparent;
      color: var(--muted); cursor: pointer;
      font-family: 'Plus Jakarta Sans', sans-serif; font-size: 12.5px; font-weight: 600;
      transition: all 0.15s;
    }

    .pag-btn:hover { border-color: var(--accent); color: var(--text); }
    .pag-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; }
    .pag-btn:disabled { opacity: 0.32; cursor: not-allowed; }

    .empty-state { text-align: center; padding: 50px 20px; color: var(--muted); }
    .empty-state i { font-size: 36px; display: block; margin-bottom: 10px; opacity: 0.38; }
    .loading { text-align: center; padding: 34px; color: var(--muted); }

    /* MODALS */
    .modal-overlay {
      position: fixed; inset: 0;
      background: rgba(15,22,35,0.48);
      backdrop-filter: blur(4px);
      z-index: 200;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none; transition: opacity 0.2s;
    }

    .modal-overlay.open { opacity: 1; pointer-events: all; }

    .modal {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 20px; padding: 30px;
      width: 100%; max-width: 520px;
      transform: scale(0.96) translateY(12px);
      transition: transform 0.25s cubic-bezier(.34,1.56,.64,1);
      box-shadow: 0 24px 60px rgba(0,0,0,0.13);
    }

    .modal-overlay.open .modal { transform: scale(1) translateY(0); }

    .modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; }
    .modal-title { font-size: 18px; font-weight: 700; }

    .btn-close {
      width: 30px; height: 30px; border-radius: 8px;
      border: 1px solid var(--border); background: transparent; color: var(--muted);
      cursor: pointer; font-size: 15px; display: flex; align-items: center; justify-content: center;
      transition: all 0.15s;
    }

    .btn-close:hover { color: var(--text); border-color: #94a3b8; }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 13px; }
    .form-grid .full { grid-column: 1 / -1; }

    .field label {
      display: block; font-size: 11px; font-weight: 700;
      color: var(--muted); text-transform: uppercase;
      letter-spacing: 0.07em; margin-bottom: 6px;
    }

    .field input, .field select {
      width: 100%; background: var(--bg); border: 1px solid var(--border);
      border-radius: 10px; padding: 10px 13px; color: var(--text);
      font-family: 'Plus Jakarta Sans', sans-serif; font-size: 13.5px;
      outline: none; transition: border-color 0.2s, background 0.2s;
    }

    .field input:focus { border-color: var(--accent); background: #fff; }

    .modal-footer { display: flex; gap: 10px; margin-top: 20px; justify-content: flex-end; }

    .btn-cancel {
      padding: 10px 20px; border-radius: 10px; border: 1px solid var(--border);
      background: transparent; color: var(--muted);
      font-family: 'Plus Jakarta Sans', sans-serif; font-size: 13.5px; font-weight: 600;
      cursor: pointer; transition: all 0.15s;
    }

    .btn-cancel:hover { color: var(--text); border-color: #94a3b8; }

    .btn-primary {
      display: flex; align-items: center; gap: 8px;
      background: var(--accent); border: none; border-radius: 10px;
      color: #fff; font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 13.5px; font-weight: 700; padding: 10px 22px;
      cursor: pointer; box-shadow: 0 4px 14px rgba(124,92,252,0.28);
      transition: all 0.15s;
    }

    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(124,92,252,0.38); }

    .field-locked { opacity: 0.48; cursor: not-allowed; }
    .lock-icon { font-size: 9px; color: var(--muted); margin-right: 3px; }

    .btn-eval {
      padding: 10px 14px; border-radius: 10px;
      border: 1px solid rgba(124,92,252,0.22);
      background: var(--accent-light); color: var(--accent);
      font-family: 'Plus Jakarta Sans', sans-serif; font-size: 13px; font-weight: 600;
      cursor: pointer; display: flex; align-items: center; gap: 6px;
      transition: all 0.15s;
    }

    .btn-eval:hover { background: rgba(124,92,252,0.18); }

    .criterios-accordion { display: flex; flex-direction: column; gap: 5px; margin-bottom: 14px; }

    .criterio-header {
      display: flex; align-items: center; justify-content: space-between;
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 10px; padding: 10px 13px;
      cursor: pointer; transition: background 0.15s; user-select: none;
    }

    .criterio-header:hover { background: var(--accent-light); border-color: rgba(124,92,252,0.18); }
    .criterio-header.open { border-bottom-left-radius: 0; border-bottom-right-radius: 0; border-bottom-color: transparent; background: var(--accent-light); }

    .criterio-nombre { font-size: 13px; font-weight: 500; color: var(--text); }
    .criterio-preview { display: flex; align-items: center; gap: 7px; }
    .criterio-preview .mini-stars { font-size: 11px; color: var(--warning); letter-spacing: 1px; }
    .criterio-preview .chevron { font-size: 11px; color: var(--muted); transition: transform 0.2s; }
    .criterio-header.open .chevron { transform: rotate(180deg); }

    .criterio-panel {
      background: var(--bg); border: 1px solid var(--border);
      border-top: none; border-bottom-left-radius: 10px;
      border-bottom-right-radius: 10px; padding: 10px 14px; display: none;
    }

    .criterio-panel.open { display: flex; justify-content: center; }

    .stars { display: flex; gap: 6px; }
    .star { font-size: 24px; cursor: pointer; color: #d1d5db; transition: color 0.1s; user-select: none; }
    .star.activa { color: var(--warning); }
    .star:hover { color: #fbbf24; }

    .eval-resultado {
      display: flex; align-items: center; justify-content: space-between;
      background: var(--accent-light); border: 1px solid rgba(124,92,252,0.18);
      border-radius: 12px; padding: 11px 16px; margin-bottom: 13px;
    }

    .eval-resultado span:first-child { font-size: 13px; color: var(--muted); }
    .nota-resultado { font-size: 24px; font-weight: 800; color: var(--accent); }
    .eval-subtitle { font-size: 12px; color: var(--muted); margin: 0 0 12px; }

    textarea {
      width: 100%; background: var(--bg); border: 1px solid var(--border);
      border-radius: 10px; padding: 10px 12px; color: var(--text);
      font-family: 'Plus Jakarta Sans', sans-serif; font-size: 13.5px;
      resize: vertical; box-sizing: border-box; outline: none; transition: border-color 0.2s;
    }

    textarea:focus { border-color: var(--accent); background: #fff; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }

body.light {
  --bg: #f4f6fb;
  --surface: #ffffff;
  --border: #e8ecf4;
  --text: #1a1f36;
  --muted: #8a94ad;
}

/* ══════════════ CHAT PANEL ══════════════ */
.chat-overlay {
  position: fixed; inset: 0;
  background: rgba(15,22,35,0.4);
  backdrop-filter: blur(3px);
  z-index: 300;
  opacity: 0; pointer-events: none;
  transition: opacity 0.25s;
}
.chat-overlay.open { opacity: 1; pointer-events: all; }

/* Panel redimensionable */
.chat-panel {
  position: fixed;
  top: 0; right: 0; bottom: 0;
  width: 380px;
  min-width: 300px;
  max-width: 70vw;
  background: var(--surface);
  border-left: 1px solid var(--border);
  z-index: 301;
  display: flex; flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.3s cubic-bezier(.4,0,.2,1);
  box-shadow: -8px 0 32px rgba(0,0,0,0.1);
}
.chat-panel.open { transform: translateX(0); }

/* Handle para redimensionar */
.chat-resize-handle {
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 6px;
  cursor: ew-resize;
  background: transparent;
  transition: background 0.2s;
  z-index: 10;
}
.chat-resize-handle:hover { background: rgba(124,92,252,0.3); }


.chat-panel-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18px 20px;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
  flex-shrink: 0;
}

.chat-estado { font-size: 11px; color: var(--muted); margin-top: 1px; }
.chat-estado.online { color: #22c55e; }

.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  background: var(--bg);
}

.chat-loading {
  text-align: center; color: var(--muted);
  font-size: 13px; padding: 20px;
}

/* Burbujas */
.chat-bubble-wrap {
  position: relative;
}
.chat-msg-arrow {
  position: absolute;
  top: 6px;
  right: 6px;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: rgba(0,0,0,0.35);
  color: #fff;
  font-size: 13px;
  display: none;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 10;
  user-select: none;
  backdrop-filter: blur(4px);
}


.message-menu-btn {
  position: absolute;
  top: -8px;
  right: -5px;
  width: 28px;
  height: 28px;
  border: none;
  border-radius: 50%;
  background: rgba(20,20,30,0.95);
  color: white;
  cursor: pointer;
  display: none;
  z-index: 20;
  font-size: 14px;
  transition: 0.2s;
}
.message-menu-btn:hover {
  background: #7c5cfc;
}

.message-dropdown {
  position: absolute;
  top: 28px;
  right: 0;
  min-width: 180px;
  background: #111827;
  border: 1px solid #2a3550;
  border-radius: 12px;
  overflow: hidden;
  z-index: 999;
  box-shadow: 0 10px 30px rgba(0,0,0,.35);
  display: none;
}

.message-dropdown.show {
  display: block;
}

.message-dropdown button {
  width: 100%;
  border: none;
  background: transparent;
  color: white;
  padding: 14px;
  text-align: left;
  cursor: pointer;
  font-size: 14px;
}

.message-dropdown button:hover {
  background: rgba(124,92,252,.12);
}

.message-select {
  position: absolute;
  left: -28px;
  top: 18px;
  display: none;
}

.selection-mode .message-select {
  display: block;
}

.delete-actions {
  position: sticky;
  bottom: 0;
  background: #1a1338;
  padding: 14px;
  display: none;
  gap: 12px;
  border-top: 1px solid rgba(255,255,255,.08);
}

.delete-actions.show {
  display: flex;
}

.chat-bubble-wrap.sent .chat-msg-arrow {
  right: 6px;
}
.chat-bubble-wrap.received .chat-msg-arrow {
  right: 6px;
}

.chat-bubble-wrap:hover .chat-msg-arrow {
  display: flex;
}

/* Menú flotante */
.chat-ctx-menu {
  position: fixed;
  z-index: 9999;
  background: var(--card, #1e293b);
  border: 1px solid var(--border, #334155);
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  min-width: 160px;
  display: none;
}
.chat-ctx-menu.visible {
  display: block;
}
.chat-ctx-menu-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 16px;
  font-size: 13px;
  cursor: pointer;
  color: var(--text, #f1f5f9);
  transition: background 0.15s;
}
.chat-ctx-menu-item:hover {
  background: rgba(124,92,252,0.15);
}
.chat-ctx-menu-item.danger {
  color: #ef4444;
}
.chat-ctx-menu-item.danger:hover {
  background: rgba(239,68,68,0.12);
}

/* Modo selección */
.chat-messages.selection-mode .chat-bubble-wrap {
  cursor: pointer;
  padding-left: 36px;
}
.chat-select-check {
  position: absolute;
  left: 8px;
  top: 50%;
  transform: translateY(-50%);
  display: none;
}
.chat-messages.selection-mode .chat-select-check {
  display: block;
}
.chat-select-check input[type="checkbox"] {
  width: 18px;
  height: 18px;
  accent-color: var(--accent, #7c5cfc);
  cursor: pointer;
}

/* Barra de acciones modo selección */
.chat-selection-bar {
  display: none;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  padding: 10px 14px;
  background: var(--surface, #111827);
  border-top: 1px solid var(--border, #1e293b);
}
.chat-selection-bar.visible {
  display: flex;
}
.chat-sel-count {
  font-size: 13px;
  color: var(--muted, #94a3b8);
}
.chat-sel-actions {
  display: flex;
  gap: 8px;
}
.chat-sel-btn {
  padding: 6px 14px;
  border-radius: 8px;
  border: none;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
}
.chat-sel-btn.for-me {
  background: rgba(100,116,139,0.25);
  color: var(--text, #f1f5f9);
}
.chat-sel-btn.for-all {
  background: #ef4444;
  color: #fff;
}
.chat-sel-cancel {
  background: none;
  border: none;
  color: var(--muted, #94a3b8);
  cursor: pointer;
  font-size: 20px;
  padding: 0 4px;
  line-height: 1;
}
.chat-sel-cancel:hover {
  color: var(--text, #f1f5f9);
}

.delete-actions button {
  border: none;
  padding: 12px 18px;
  border-radius: 10px;
  cursor: pointer;
  font-weight: 600;
}

.btn-delete-me {
  background: #334155;
  color: white;
}

.btn-delete-all {
  background: #ef4444;
  color: white;
}

.chat-bubble-wrap:hover .message-menu-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Burbujas - PROPIOS a la derecha */
.chat-bubble-wrap.sent {
  align-self: flex-end;
  align-items: flex-end;
  max-width: 80%;
}
.chat-bubble-wrap.received {
  align-self: flex-start;
  align-items: flex-start;
  max-width: 80%;
}

.chat-sender {
  font-size: 11px; font-weight: 600;
  color: var(--muted); margin-bottom: 3px;
  display: flex; align-items: center; gap: 6px;
}
/* Nombre del remitente */
.chat-sender-name {
  font-size: 11px; font-weight: 700;
  color: var(--accent);
  margin-bottom: 3px;
  display: flex; align-items: center; gap: 5px;
}

/* Mi nombre a la derecha */
.chat-bubble-wrap.sent .chat-sender-name {
  color: var(--muted);
  flex-direction: row-reverse;
}

.chat-avatar-mini {
  width: 22px; height: 22px; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), #06b6d4);
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 800; color: #fff;
  flex-shrink: 0;
}

.chat-bubble {
  padding: 10px 14px;
  border-radius: 16px;
  font-size: 13.5px;
  line-height: 1.45;
  word-break: break-word;
}

.chat-bubble-wrap.sent .chat-bubble {
  background: var(--accent);
  color: #fff;
  border-radius: 16px 16px 4px 16px;
}
.chat-bubble-wrap.received .chat-bubble {
  background: var(--surface);
  color: var(--text);
  border: 1px solid var(--border);
  border-radius: 16px 16px 16px 4px;
}

.chat-bubble img {
  max-width: 100%; border-radius: 10px;
  cursor: pointer; display: block;
  margin-top: 4px;
}

.chat-time {
  font-size: 10.5px; color: var(--muted);
  margin-top: 3px;
}

.chat-bubble-wrap.sent .chat-time { text-align: right; }

/* Input area */
.chat-input-area {
  display: flex; align-items: center; gap: 8px;
  padding: 12px 16px;
  border-top: 1px solid var(--border);
  background: var(--surface);
  flex-shrink: 0;
}

.chat-attach-btn {
  width: 36px; height: 36px;
  border-radius: 10px;
  border: 1px solid var(--border);
  background: var(--bg);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: var(--muted);
  font-size: 16px; flex-shrink: 0;
  transition: all 0.15s;
}

.chat-attach-btn:hover { border-color: var(--accent); color: var(--accent); }

.chat-text-input {
  flex: 1;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 9px 13px;
  color: var(--text);
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 13.5px;
  outline: none;
  transition: border-color 0.2s;
}

.chat-text-input:focus { border-color: var(--accent); background: var(--surface); }
.chat-text-input::placeholder { color: var(--muted); }

.chat-send-btn {
  width: 36px; height: 36px;
  border-radius: 10px;
  background: var(--accent);
  border: none; color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; cursor: pointer;
  flex-shrink: 0;
  transition: all 0.15s;
  box-shadow: 0 3px 10px rgba(124,92,252,0.3);
}

.chat-send-btn:hover { transform: scale(1.05); }
.chat-send-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

/* Preview imagen */
.chat-preview {
  padding: 8px 16px;
  border-top: 1px solid var(--border);
  background: var(--surface);
  position: relative;
  flex-shrink: 0;
}

.chat-preview img {
  height: 80px; border-radius: 8px;
  object-fit: cover;
}

.chat-preview-cancel {
  position: absolute; top: 4px; right: 12px;
  background: none; border: none;
  color: var(--danger); font-size: 18px;
  cursor: pointer;
}



/* dark mode chat */
body.dark .chat-panel { background: #111827; border-color: #1e293b; }
body.dark .chat-panel-header { background: #111827; border-color: #1e293b; }
body.dark .chat-messages { background: #0b0f1a; }
body.dark .chat-bubble-wrap.received .chat-bubble { background: #1a2234; border-color: #1e293b; color: #f1f5f9; }
body.dark .chat-input-area { background: #111827; border-color: #1e293b; }
body.dark .chat-text-input { background: #0b0f1a; border-color: #1e293b; color: #f1f5f9; }
body.dark .chat-attach-btn { background: #0b0f1a; border-color: #1e293b; }
body.dark .chat-preview { background: #111827; border-color: #1e293b; }
  </style>
