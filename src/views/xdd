  <div class="chat-panel-header">
    <div style="display:flex;align-items:center;gap:10px;">
      <div style="width:36px;height:36px;border-radius:10px;background:var(--accent);display:flex;align-items:center;justify-content:center;color:#fff;font-size:16px;">
        <i class="bi bi-chat-dots-fill"></i>
      </div>
      <div>
        <div style="font-size:14px;font-weight:700;">Chat grupal</div>
        <div class="chat-estado" id="chatEstado">● Conectando...</div>
      </div>
    </div>
    <button class="btn-close" onclick="cerrarChat()"><i class="bi bi-x"></i></button>
  </div>

  <!-- Mensajes -->
  <div class="chat-messages" id="chatMessages">
    <div class="chat-loading">Cargando mensajes...</div>
  </div>

  <!-- Preview imagen -->
  <div class="chat-preview" id="chatPreview" style="display:none;">
    <img id="chatPreviewImg" src="" alt="preview"/>
    <button onclick="cancelarImagenChat()" class="chat-preview-cancel">
      <i class="bi bi-x-circle-fill"></i>
    </button>
  </div>
<!-- Barra de selección múltiple -->
  <div class="chat-selection-bar" id="chatSelectionBar">
    <span class="chat-sel-count" id="chatSelCount">0 seleccionados</span>
    <div class="chat-sel-actions">
      <button class="chat-sel-btn for-me" onclick="eliminarSeleccionados('yo')">
        <i class="bi bi-person"></i> Eliminar para mí
      </button>
      <button class="chat-sel-btn for-all" id="btnEliminarTodos" onclick="eliminarSeleccionados('todos')">
        <i class="bi bi-people"></i> Eliminar para todos
      </button>
    </div>
    <button class="chat-sel-cancel" onclick="salirModoSeleccion()" title="Cancelar">×</button>
  </div>

  <!-- Input -->
  <div class="chat-input-area">
    <label class="chat-attach-btn" title="Adjuntar imagen">
      <i class="bi bi-image"></i>
      <input type="file" id="chatFileInput" accept="image/*" style="display:none;" onchange="seleccionarImagenChat(this)"/>
    </label>
    <input type="text" id="chatInput" class="chat-text-input"
           placeholder="Escribe un mensaje..."
           onkeydown="if(event.key==='Enter')enviarMensajeChat()"/>
    <button class="chat-send-btn" onclick="enviarMensajeChat()">
      <i class="bi bi-send-fill"></i>
    </button>
  </div>
</div>

<!-- MODAL CREAR/EDITAR -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <div class="modal-header">
      <h2 class="modal-title" id="modalTitle">Crear estudiante</h2>
      <button class="btn-close" onclick="closeModal()"><i class="bi bi-x"></i></button>
    </div>
    <div class="form-grid">
      <input type="hidden" id="editId" />
      <div class="field"><label id="lbNombre">Nombre</label><input type="text" id="fNombre" placeholder="Carlos" /></div>
      <div class="field"><label id="lbApellido">Apellido</label><input type="text" id="fApellido" placeholder="Ramírez" /></div>
      <div class="field"><label id="lbDni">DNI</label><input type="text" id="fDni" placeholder="12345678" maxlength="8" /></div>
      <div class="field"><label>Teléfono</label><input type="tel" id="fTelefono" placeholder="999 888 777" /></div>
      <div class="field full"><label id="lbCarrera">Carrera</label><input type="text" id="fCarrera" placeholder="Ingeniería de Sistemas" /></div>
      <div class="field full"><label id="lbInstitucion">Institución</label><input type="text" id="fInstitucion" placeholder="Universidad Nacional" /></div>
      <div class="field full"><label id="lbCorreo">Correo (acceso app Android)</label><input type="email" id="fCorreo" placeholder="estudiante@correo.com" /></div>
      <div class="field full"><label id="lbContrasenia">Contraseña (acceso app Android)</label><input type="password" id="fContrasenia" placeholder="••••••••" /></div>
    </div>
    <div class="modal-footer" style="justify-content:space-between;">
      <button class="btn-eval" id="btnEditarNota" onclick="abrirEval()" style="display:none;">
        <i class="bi bi-star-fill"></i> Editar nota por criterios
      </button>
      <div style="display:flex;gap:10px;">
        <button class="btn-cancel" onclick="closeModal()">Cancelar</button>
        <button class="btn-primary" onclick="guardarTelefono()"><i class="bi bi-check-lg"></i> Guardar</button>
      </div>
    </div>
  </div>
</div>

<!-- MODAL EVALUACIÓN -->
<div class="modal-overlay" id="evalOverlay">
  <div class="modal" style="max-width:520px;">
    <div class="modal-header">
      <h2 class="modal-title">Evaluación por criterios</h2>
      <button class="btn-close" onclick="closeEval()"><i class="bi bi-x"></i></button>
    </div>
    <p class="eval-subtitle">Haz clic en cada criterio para calificarlo del <strong>1</strong> (deficiente) al <strong>5</strong> (excelente)</p>
    <div class="criterios-accordion" id="criteriosList"></div>
    <div class="eval-resultado">
      <span>Nota final (0–20):</span>
      <span class="nota-resultado" id="notaResultado">—</span>
    </div>
    <div class="field full">
      <label>Comentario del supervisor</label>
      <textarea id="fComentario" rows="2" placeholder="Indicar áreas de mejora, fortalezas o recomendaciones…"></textarea>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeEval()">Cancelar</button>
      <button class="btn-primary" onclick="guardarEval()"><i class="bi bi-check-lg"></i> Guardar evaluación</button>
    </div>
  </div>
</div>

<script>
  let allData = [], filtered = [], page = 1, showAll = false;
  const perPage = 8;


function toggleTheme() {
  const isDark = document.body.classList.toggle('dark');
  document.getElementById('themeIcon').className = isDark ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
  localStorage.setItem('tema', isDark ? 'dark' : 'light');
}

if (localStorage.getItem('tema') === 'dark') {
  document.body.classList.add('dark');
  document.getElementById('themeIcon').className = 'bi bi-sun-fill';
}

  // SUPERVISOR
async function loadSupervisor() {
    try {
      const res = await fetch('/api/supervisor');
      if (res.ok) {
        const data = await res.json();
        // Para el dashboard
        setNames(data.nombre || 'Supervisor');
        // Para el chat - cargar aquí directamente
        supervisorEmail  = data.correo || '';
        supervisorNombre = data.nombre || 'Supervisor';
        console.log('✅ Supervisor listo:', supervisorEmail, supervisorNombre);
        return;
      }
    } catch(e) {}
    const stored = sessionStorage.getItem('supervisorNombre') || 'Jherson';
    setNames(stored);
}

  function setNames(nombre) {
    const initial = nombre.charAt(0).toUpperCase();
    const greeting = `¡Bienvenido, ${nombre}! 😎`;
    document.getElementById('sidebarName').textContent = nombre;
    document.getElementById('topbarName').textContent = nombre;
    document.getElementById('sidebarAvatarText').textContent = initial;
    document.getElementById('topbarAvatarText').textContent = initial;
  }

  // INPUT VALIDATION
  function soloLetras(id) {
    document.getElementById(id).addEventListener('input', function() {
      this.value = this.value.replace(/[^a-zA-ZáéíóúÁÉÍÓÚüÜñÑ\s]/g, '');
    });
  }
  function soloNumeros(id, maxLen) {
    document.getElementById(id).addEventListener('input', function() {
      this.value = this.value.replace(/\D/g, '').slice(0, maxLen);
    });
  }
  soloLetras('fNombre'); soloLetras('fApellido'); soloLetras('fCarrera'); soloLetras('fInstitucion');
  soloNumeros('fTelefono', 9); soloNumeros('fDni', 8);

  // LOAD
  async function cargar() {
    try {
      const res = await fetch('/api/estudiantes');
      allData = await res.json();
      filtered = [...allData];
      updateStats();
      renderTabla();
      renderCharts();
    } catch(e) {
      document.getElementById('tablaBody').innerHTML =
        `<tr><td colspan="9" class="loading" style="color:var(--danger);">Error al cargar datos</td></tr>`;
    }
  }

  function updateStats() {
    const total = allData.length;
    const conNota = allData.filter(e => e.nota !== null);
    const promedio = conNota.length
      ? (conNota.reduce((s,e) => s + parseFloat(e.nota), 0) / conNota.length).toFixed(1)
      : '—';
    const instituciones = [...new Set(allData.map(e => e.institucion))].length;
    document.getElementById('statTotal').textContent = total;
    document.getElementById('statPromedio').textContent = promedio;
    document.getElementById('statEval').textContent = conNota.length;
    document.getElementById('statInst').textContent = instituciones;
  }

  // CHARTS
  let donutChart, lineChart;
  const PALETTE = ['#7c5cfc','#06b6d4','#22c55e','#f59e0b','#ef4444','#8b5cf6','#ec4899'];

  function renderCharts() {
    const instMap = {};
    allData.forEach(e => { instMap[e.institucion] = (instMap[e.institucion] || 0) + 1; });
    const instLabels = Object.keys(instMap);
    const instValues = Object.values(instMap);
    const colors = instLabels.map((_, i) => PALETTE[i % PALETTE.length]);

    if (donutChart) donutChart.destroy();
    donutChart = new Chart(document.getElementById('donutChart').getContext('2d'), {
      type: 'doughnut',
      data: { labels: instLabels, datasets: [{ data: instValues, backgroundColor: colors, borderWidth: 0, hoverOffset: 6 }] },
      options: {
        cutout: '68%',
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${ctx.raw}` } } },
        animation: { animateRotate: true, duration: 800 }
      }
    });

    document.getElementById('donutLegend').innerHTML = instLabels.map((label, i) => `
      <div class="legend-item">
        <div class="legend-dot" style="background:${colors[i]};"></div>
        <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:11px;">${label}</span>
        <span>${instValues[i]}</span>
      </div>
    `).join('');

    const meses = ['Ene','Feb','Mar','Abr','May','Jun'];
    const notas = allData.map(e => e.nota ? parseFloat(e.nota) : null).filter(Boolean);
    const baseAvg = notas.length ? notas.reduce((a,b)=>a+b,0)/notas.length : 10;
    const lineData = meses.map((_, i) => +(baseAvg * (0.6 + i * 0.08) + (Math.random() - 0.5) * 2).toFixed(1));
    lineData[lineData.length-1] = +baseAvg.toFixed(1);

    if (lineChart) lineChart.destroy();
    const lCtx = document.getElementById('lineChart').getContext('2d');
    const gradient = lCtx.createLinearGradient(0, 0, 0, 200);
    gradient.addColorStop(0, 'rgba(124,92,252,0.22)');
    gradient.addColorStop(1, 'rgba(124,92,252,0)');

    lineChart = new Chart(lCtx, {
      type: 'line',
      data: {
        labels: meses,
        datasets: [{
          data: lineData, borderColor: '#7c5cfc', backgroundColor: gradient,
          borderWidth: 2.5, pointBackgroundColor: '#7c5cfc',
          pointRadius: 4, pointHoverRadius: 6, fill: true, tension: 0.4
        }]
      },
      options: {
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ` Promedio: ${ctx.raw}` } } },
        scales: {
          x: { grid: { display: false }, ticks: { font: { family: 'Plus Jakarta Sans', size: 11 }, color: '#8a94ad' } },
          y: { min: 0, max: 20, grid: { color: '#f0f2f8' }, ticks: { stepSize: 5, font: { size: 11 }, color: '#8a94ad' } }
        },
        animation: { duration: 900 }
      }
    });
  }

  // TABLE
  function renderTabla() {
    const tbody = document.getElementById('tablaBody');
    const total = filtered.length;

    if (total === 0) {
      tbody.innerHTML = `<tr><td colspan="9"><div class="empty-state"><i class="bi bi-inbox"></i><br>No hay estudiantes registrados</div></td></tr>`;
      document.getElementById('pagInfo').textContent = 'Sin resultados';
      document.getElementById('pagControls').innerHTML = '';
      return;
    }

    const start = (page - 1) * perPage;
    const slice = showAll ? filtered : filtered.slice(start, start + perPage);

    tbody.innerHTML = slice.map(e => `
      <tr>
        <td>
          <div style="display:flex;align-items:center;gap:9px;">
            <div style="width:31px;height:31px;border-radius:50%;background:${avatarColor(e.nombre)};display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0;">${e.nombre.charAt(0).toUpperCase()}</div>
            <div class="name-cell">${e.nombre} ${e.apellido}<small>${e.carrera}</small></div>
          </div>
        </td>
        <td class="dni-cell">${e.dni}</td>
        <td style="font-size:12.5px;">${e.carrera}</td>
        <td style="font-size:12px;color:var(--muted);max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${e.institucion}</td>
        <td>${notaBadge(e.nota)}</td>
        <td style="font-size:12.5px;color:var(--muted);">${e.telefono || '—'}</td>
        <td style="font-size:12px;color:var(--muted);">${e.correo || '—'}</td>
        <td><span class="estado-badge">Activo</span></td>
        <td>
          <div class="actions">
            <button class="btn-icon edit" title="Editar" onclick="editar(${e.id_estudiante})"><i class="bi bi-pencil"></i></button>
            <button class="btn-icon del" title="Eliminar" onclick="eliminar(${e.id_estudiante}, '${e.nombre} ${e.apellido}')"><i class="bi bi-trash"></i></button>
          </div>
        </td>
      </tr>
    `).join('');

    if (!showAll) {
      const totalPages = Math.ceil(total / perPage);
      document.getElementById('pagInfo').textContent = `Mostrando ${start+1}–${Math.min(start+perPage,total)} de ${total} registros`;
      let html = `<button class="pag-btn" onclick="goPage(${page-1})" ${page===1?'disabled':''}><i class="bi bi-chevron-left"></i></button>`;
      for (let i = 1; i <= totalPages; i++) html += `<button class="pag-btn ${i===page?'active':''}" onclick="goPage(${i})">${i}</button>`;
      html += `<button class="pag-btn" onclick="goPage(${page+1})" ${page===totalPages?'disabled':''}><i class="bi bi-chevron-right"></i></button>`;
      document.getElementById('pagControls').innerHTML = html;
    } else {
      document.getElementById('pagInfo').textContent = `${total} registros`;
      document.getElementById('pagControls').innerHTML = '';
    }
  }

  function avatarColor(nombre) {
    const colors = ['#7c5cfc','#06b6d4','#22c55e','#f59e0b','#ef4444','#3b82f6','#ec4899','#8b5cf6'];
    let hash = 0;
    for (let i = 0; i < nombre.length; i++) hash = nombre.charCodeAt(i) + ((hash << 5) - hash);
    return colors[Math.abs(hash) % colors.length];
  }

  function notaBadge(nota) {
    if (nota === null || nota === undefined) return `<span class="nota-badge nota-none">S/N</span>`;
    const n = parseFloat(nota);
    const cls = n >= 14 ? 'nota-high' : n >= 11 ? 'nota-mid' : 'nota-low';
    return `<span class="nota-badge ${cls}">${n.toFixed(1)}</span>`;
  }

  function goPage(p) {
    const max = Math.ceil(filtered.length / perPage);
    if (p < 1 || p > max) return;
    page = p; renderTabla();
  }

  function scrollToTable() {
    document.getElementById('tableAnchor').scrollIntoView({ behavior:'smooth', block:'start' });
  }

  document.getElementById('verTodosLink').addEventListener('click', () => {
    showAll = !showAll;
    document.getElementById('verTodosLink').textContent = showAll ? 'Ver menos' : 'Ver todos';
    page = 1; renderTabla();
  });

  document.getElementById('searchInput').addEventListener('input', function() {
    const q = this.value.toLowerCase();
    filtered = allData.filter(e =>
      `${e.nombre} ${e.apellido}`.toLowerCase().includes(q) ||
      e.dni.toLowerCase().includes(q) ||
      e.carrera.toLowerCase().includes(q)
    );
    page = 1; renderTabla();
  });

  // MODAL
  const CAMPOS_BLOQUEABLES = ['fNombre','fApellido','fDni','fCarrera','fInstitucion','fCorreo','fContrasenia'];
  const LABELS_BLOQUEABLES = ['lbNombre','lbApellido','lbDni','lbCarrera','lbInstitucion','lbCorreo','lbContrasenia'];
  const NOMBRES_LABEL      = ['Nombre','Apellido','DNI','Carrera','Institución','Correo (acceso app Android)','Contraseña (acceso app Android)'];

  function setModoEditar(esEditar) {
    CAMPOS_BLOQUEABLES.forEach((id, i) => {
      const el = document.getElementById(id);
      const lb = document.getElementById(LABELS_BLOQUEABLES[i]);
      if (esEditar) { el.readOnly = true; el.classList.add('field-locked'); lb.innerHTML = `<i class="bi bi-lock-fill lock-icon"></i> ${NOMBRES_LABEL[i]}`; }
      else { el.readOnly = false; el.classList.remove('field-locked'); lb.textContent = NOMBRES_LABEL[i]; }
    });
    document.getElementById('btnEditarNota').style.display = esEditar ? 'flex' : 'none';
    document.getElementById('modalTitle').textContent = esEditar ? 'Editar estudiante' : 'Crear estudiante';
    document.querySelector('#modalOverlay .btn-primary').setAttribute('onclick', esEditar ? 'guardarTelefono()' : 'guardar()');
  }

  function openModal(data = null) {
    const esEditar = !!data;
    document.getElementById('editId').value       = data?.id_estudiante || '';
    document.getElementById('fNombre').value      = data?.nombre || '';
    document.getElementById('fApellido').value    = data?.apellido || '';
    document.getElementById('fDni').value         = data?.dni || '';
    document.getElementById('fCarrera').value     = data?.carrera || '';
    document.getElementById('fInstitucion').value = data?.institucion || '';
    document.getElementById('fCorreo').value      = data?.correo || '';
    document.getElementById('fTelefono').value    = data?.telefono || '';
    document.getElementById('fContrasenia').value = esEditar ? '••••••••' : '';
    setModoEditar(esEditar);
    document.getElementById('modalOverlay').classList.add('open');
  }

  function closeModal() { document.getElementById('modalOverlay').classList.remove('open'); }
  document.getElementById('modalOverlay').addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(); });

  async function editar(id) {
    const est = allData.find(e => e.id_estudiante === id);
    if (est) openModal(est);
  }

  function validarFormCrear() {
    const campos = ['fNombre','fApellido','fDni','fCarrera','fInstitucion','fCorreo','fContrasenia'];
    for (const id of campos) {
      if (!document.getElementById(id).value.trim()) {
        Swal.fire({ icon:'warning', title:'Campos requeridos', text:'Completa todos los campos obligatorios.' });
        return false;
      }
    }
    if (document.getElementById('fDni').value.trim().length !== 8) {
      Swal.fire({ icon:'warning', title:'DNI inválido', text:'El DNI debe tener exactamente 8 dígitos.' });
      return false;
    }
    const correo = document.getElementById('fCorreo').value.trim();
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(correo)) {
      Swal.fire({ icon:'warning', title:'Correo inválido', text:'Ingresa un correo con formato válido.' });
      return false;
    }
    const tel = document.getElementById('fTelefono').value.trim();
    if (tel && tel.length !== 9) {
      Swal.fire({ icon:'warning', title:'Teléfono inválido', text:'El teléfono debe tener exactamente 9 dígitos.' });
      return false;
    }
    return true;
  }

  async function guardar() {
    if (!validarFormCrear()) return;
    const body = {
      nombre: document.getElementById('fNombre').value.trim(),
      apellido: document.getElementById('fApellido').value.trim(),
      dni: document.getElementById('fDni').value.trim(),
      carrera: document.getElementById('fCarrera').value.trim(),
      institucion: document.getElementById('fInstitucion').value.trim(),
      correo: document.getElementById('fCorreo').value.trim(),
      contrasenia: document.getElementById('fContrasenia').value,
      telefono: document.getElementById('fTelefono').value.trim(),
    };
    try {
      const res = await fetch('/api/estudiantes', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
      const data = await res.json();
      if (data.success) { closeModal(); await cargar(); Swal.fire({ icon:'success', title:'¡Registrado!', timer:1500, showConfirmButton:false }); }
    } catch(e) { Swal.fire({ icon:'error', title:'Error', text:'No se pudo guardar.' }); }
  }

  async function guardarTelefono() {
    const id = document.getElementById('editId').value;
    if (!id) return;
    const telefono = document.getElementById('fTelefono').value.trim();
    if (telefono && telefono.length !== 9) {
      Swal.fire({ icon:'warning', title:'Teléfono inválido', text:'El teléfono debe tener exactamente 9 dígitos.' });
      return;
    }
    try {
      const res = await fetch(`/api/estudiantes/${id}/telefono`, { method:'PATCH', headers:{'Content-Type':'application/json'}, body:JSON.stringify({telefono}) });
      const data = await res.json();
      if (data.success) { closeModal(); await cargar(); Swal.fire({ icon:'success', title:'¡Actualizado!', timer:1500, showConfirmButton:false }); }
    } catch(e) { Swal.fire({ icon:'error', title:'Error', text:'No se pudo guardar.' }); }
  }

  async function eliminar(id, nombre) {
    const result = await Swal.fire({
      title:'¿Eliminar estudiante?', text:`Se eliminará a ${nombre} permanentemente.`,
      icon:'warning', showCancelButton:true, confirmButtonText:'Sí, eliminar',
      cancelButtonText:'Cancelar', confirmButtonColor:'#ef4444',
    });
    if (!result.isConfirmed) return;
    try {
      const res = await fetch(`/api/estudiantes/${id}`, { method:'DELETE' });
      const data = await res.json();
      if (data.success) { await cargar(); Swal.fire({ icon:'success', title:'Eliminado', timer:1200, showConfirmButton:false }); }
    } catch(e) { Swal.fire({ icon:'error', title:'Error', text:'No se pudo eliminar.' }); }
  }

  // EVAL MODAL
  const CRITERIOS = ['Asistencia y puntualidad','Responsabilidad','Actitud y comportamiento','Trabajo en equipo','Calidad del trabajo','Cumplimiento de normas','Aprendizaje y adaptación'];
  let puntajes = new Array(CRITERIOS.length).fill(0);

  function renderCriterios() {
    document.getElementById('criteriosList').innerHTML = CRITERIOS.map((nombre, i) => {
      const miniStars = puntajes[i] > 0 ? '★'.repeat(puntajes[i]) + '☆'.repeat(5 - puntajes[i]) : '☆☆☆☆☆';
      return `<div>
        <div class="criterio-header" id="header-${i}" onclick="toggleCriterio(${i})">
          <span class="criterio-nombre">${nombre}</span>
          <div class="criterio-preview">
            <span class="mini-stars" id="mini-${i}">${miniStars}</span>
            <span class="chevron">▼</span>
          </div>
        </div>
        <div class="criterio-panel" id="panel-${i}">
          <div class="stars" id="stars-${i}">
            ${[1,2,3,4,5].map(v => `<span class="star ${puntajes[i]>=v?'activa':''}" onclick="setPuntaje(${i},${v},event)">★</span>`).join('')}
          </div>
        </div>
      </div>`;
    }).join('');
    actualizarNota();
  }

  function toggleCriterio(idx) {
    const header = document.getElementById(`header-${idx}`);
    const panel  = document.getElementById(`panel-${idx}`);
    const isOpen = panel.classList.contains('open');
    document.querySelectorAll('.criterio-panel').forEach(p => p.classList.remove('open'));
