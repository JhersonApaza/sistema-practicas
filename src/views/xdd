  function setPuntaje(idx, valor, event) {
    if (event) event.stopPropagation();
    puntajes[idx] = valor;
    document.getElementById(`stars-${idx}`).innerHTML =
      [1,2,3,4,5].map(v => `<span class="star ${puntajes[idx]>=v?'activa':''}" onclick="setPuntaje(${idx},${v},event)">★</span>`).join('');
    document.getElementById(`mini-${idx}`).textContent = '★'.repeat(valor) + '☆'.repeat(5-valor);
    actualizarNota();
  }

  function actualizarNota() {
    const promedio = puntajes.reduce((a,b)=>a+b,0)/CRITERIOS.length;
    document.getElementById('notaResultado').textContent = promedio===0 ? '—' : (promedio*4).toFixed(2);
  }

  function abrirEval() {
    const id = document.getElementById('editId').value;
    if (!id) return;
    const est = allData.find(e => e.id_estudiante == id);
    puntajes = new Array(CRITERIOS.length).fill(0);
    document.getElementById('fComentario').value = est?.comentario || '';
    renderCriterios();
    document.getElementById('evalOverlay').classList.add('open');
  }

  function closeEval() { document.getElementById('evalOverlay').classList.remove('open'); }
  document.getElementById('evalOverlay').addEventListener('click', e => { if (e.target===e.currentTarget) closeEval(); });

  async function guardarEval() {
    const id = document.getElementById('editId').value;
    if (!id) return;
    if (puntajes.every(p=>p===0)) { Swal.fire({ icon:'warning', title:'Sin calificar', text:'Debes calificar al menos un criterio.' }); return; }
    const promedio = puntajes.reduce((a,b)=>a+b,0)/CRITERIOS.length;
    const nota = parseFloat((promedio*4).toFixed(2));
    const comentario = document.getElementById('fComentario').value.trim();
    try {
      const res = await fetch(`/api/estudiantes/${id}/nota`, {
        method:'PATCH', headers:{'Content-Type':'application/json'},
        body:JSON.stringify({nota, comentario})
      });
      const data = await res.json();
      if (data.success) {
        closeEval(); closeModal(); await cargar();
        Swal.fire({ icon:'success', title:'¡Evaluación guardada!', text:`Nota: ${nota}`, timer:2000, showConfirmButton:false });
      }
    } catch(e) { Swal.fire({ icon:'error', title:'Error', text:'No se pudo guardar la evaluación.' }); }
  }



  // ═══════════════════════════════════════
  // CHAT
