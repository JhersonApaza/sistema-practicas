async function abrirChat() {
    document.getElementById('chatOverlay').classList.add('open');
    document.getElementById('chatPanel').classList.add('open');

    if (!supervisorEmail) {
      await loadSupervisor(); // ← cambia cargarDatosSupervisor() por loadSupervisor()
    }

    iniciarPollingChat();
}

    // INIT
  loadSupervisor();
  cargar();

  function cerrarChat() {
    document.getElementById('chatOverlay').classList.remove('open');
    document.getElementById('chatPanel').classList.remove('open');
    detenerPollingChat();
  }

  function iniciarPollingChat() {
    cargarMensajesChat();
    chatPolling = setInterval(cargarMensajesChat, 3000);
  }

  function detenerPollingChat() {
    clearInterval(chatPolling);
    chatPolling = null;
  }

  async function cargarMensajesChat() {
    try {
      const res = await fetch('/api/chat/mensajes');
      const data = await res.json();
      if (data && data.data) {
        chatMensajes = data.data;
        renderMensajesChat();
        setEstadoChat(true);
      }
    } catch(e) {
      setEstadoChat(false);
    }
  }

  function setEstadoChat(ok) {
    const el = document.getElementById('chatEstado');
    if (!el) return;
    el.textContent = ok ? '● En línea' : '● Sin conexión';
    el.className = 'chat-estado ' + (ok ? 'online' : '');
  }

function renderMensajesChat() {
  const container = document.getElementById('chatMessages');
  if (!container) return;

  const atBottom = container.scrollHeight - container.scrollTop - container.clientHeight < 60;

  if (chatMensajes.length === 0) {
    container.innerHTML = '<div class="chat-loading">No hay mensajes aún. ¡Sé el primero!</div>';
    return;
  }

  container.innerHTML = chatMensajes.map(m => {
    const esMio = m.email && supervisorEmail &&
                  m.email.toLowerCase() === supervisorEmail.toLowerCase();

    const nombre = m.nombre || m.email || 'Supervisor';
    const inicial = nombre.charAt(0).toUpperCase();
    const hora = formatearHoraChat(m.fecha);
    const avatarColor = stringToColor(nombre);

    const bubbleContent = `
      ${m.mensaje ? `<div>${escapeHtml(m.mensaje)}</div>` : ''}
      ${m.imagen_url ? `<img src="${m.imagen_url}" alt="imagen"
        onclick="verImagenChat('${m.imagen_url}')"
        loading="lazy" style="max-width:100%;border-radius:10px;margin-top:4px;cursor:pointer;display:block;"/>` : ''}
    `;

    // Flecha del menú contextual
    const arrow = `<span class="chat-msg-arrow" onclick="abrirMenuMensaje(event,${m.id},${esMio})">▾</span>`;
    // Checkbox de selección
    const check = `<span class="chat-select-check"><input type="checkbox" data-id="${m.id}" onchange="onCheckMensaje(this)"/></span>`;

    if (esMio) {
      return `
        <div class="chat-bubble-wrap sent" data-id="${m.id}" onclick="onBubbleClick(event,${m.id})">
          ${check}
          ${arrow}
          <div class="chat-bubble">${bubbleContent}</div>
          <div class="chat-time">${hora}</div>
        </div>`;
    } else {
      return `
        <div class="chat-bubble-wrap received" data-id="${m.id}" onclick="onBubbleClick(event,${m.id})">
          ${check}
          ${arrow}
          <div class="chat-sender-name">
            <div class="chat-avatar-mini" style="background:${avatarColor};">${inicial}</div>
            ${escapeHtml(nombre)}
          </div>
          <div class="chat-bubble">${bubbleContent}</div>
          <div class="chat-time">${hora}</div>
        </div>`;
    }
  }).join('');

  if (atBottom) container.scrollTop = container.scrollHeight;
}

// ── Menú contextual tipo WhatsApp ──────────────────────

let _ctxMsgId   = null;   // id del mensaje que abrió el menú
let _ctxEsMio   = false;  // si el mensaje es del supervisor

function abrirMenuMensaje(event, id, esMio) {
  event.stopPropagation();

  _ctxMsgId = id;
  _ctxEsMio = esMio;

  // Ocultar "Editar" si no es mío
  const editItem = document.getElementById('chatCtxEdit');
  if (editItem) editItem.style.display = esMio ? 'flex' : 'none';

  const menu = document.getElementById('chatCtxMenu');
  menu.classList.add('visible');

  // Posicionar cerca del click sin salirse de pantalla
  let x = event.clientX;
  let y = event.clientY;
  const w = 180, h = 90;
  if (x + w > window.innerWidth)  x = window.innerWidth - w - 8;
  if (y + h > window.innerHeight) y = window.innerHeight - h - 8;

  menu.style.left = x + 'px';
  menu.style.top  = y + 'px';
}

function cerrarMenuMensaje() {
  const menu = document.getElementById('chatCtxMenu');
  if (menu) menu.classList.remove('visible');
  _ctxMsgId = null;
}

// Cerrar menú al hacer clic en cualquier otro lugar
document.addEventListener('click', function(e) {
  const menu = document.getElementById('chatCtxMenu');
  if (menu && menu.classList.contains('visible') && !menu.contains(e.target)) {
    cerrarMenuMensaje();
  }
});

// ── Editar mensaje ─────────────────────────────────────

async function editarMensajeChat() {
  cerrarMenuMensaje();
  if (!_ctxMsgId) return;

  const msg = chatMensajes.find(m => m.id === _ctxMsgId);
  if (!msg || !msg.mensaje) return;

  const { value: nuevoTexto } = await Swal.fire({
    title: 'Editar mensaje',
    input: 'textarea',
    inputValue: msg.mensaje,
    inputAttributes: { rows: 3 },
    showCancelButton: true,
    confirmButtonText: 'Guardar',
    cancelButtonText: 'Cancelar',
    confirmButtonColor: '#7c5cfc',
    background: document.body.classList.contains('light') ? '#fff' : '#111827',
    color: document.body.classList.contains('light') ? '#0f172a' : '#f1f5f9'
  });

  if (!nuevoTexto || nuevoTexto.trim() === msg.mensaje) return;

  try {
    const res = await fetch(`/api/chat/${_ctxMsgId}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mensaje: nuevoTexto.trim() })
    });
    if (res.ok) {
      await cargarMensajesChat();
    }
  } catch(e) {
    console.error('Error editando mensaje:', e);
  }
}

// ── Modo selección múltiple ────────────────────────────

let modoSeleccion = false;
let mensajesSeleccionados = new Set();

function activarModoSeleccion() {
  cerrarMenuMensaje();
  modoSeleccion = true;
  mensajesSeleccionados.clear();

  const container = document.getElementById('chatMessages');
  if (container) container.classList.add('selection-mode');

  // Si había un mensaje en contexto, marcarlo automáticamente
  if (_ctxMsgId) {
    const cb = document.querySelector(`.chat-select-check input[data-id="${_ctxMsgId}"]`);
    if (cb) {
      cb.checked = true;
      mensajesSeleccionados.add(_ctxMsgId);
    }
  }

  actualizarBarraSeleccion();

  const bar = document.getElementById('chatSelectionBar');
  if (bar) bar.classList.add('visible');

  const inputArea = document.querySelector('.chat-input-area');
  if (inputArea) inputArea.style.display = 'none';
}

function salirModoSeleccion() {
  modoSeleccion = false;
  mensajesSeleccionados.clear();

  const container = document.getElementById('chatMessages');
  if (container) container.classList.remove('selection-mode');

  // Desmarcar todos
  document.querySelectorAll('.chat-select-check input[type="checkbox"]')
    .forEach(cb => cb.checked = false);

  const bar = document.getElementById('chatSelectionBar');
  if (bar) bar.classList.remove('visible');

  const inputArea = document.querySelector('.chat-input-area');
  if (inputArea) inputArea.style.display = '';
}

function onCheckMensaje(cb) {
  const id = parseInt(cb.dataset.id);
  if (cb.checked) {
    mensajesSeleccionados.add(id);
  } else {
    mensajesSeleccionados.delete(id);
  }
  actualizarBarraSeleccion();
}

function onBubbleClick(event, id) {
  if (!modoSeleccion) return;
  // Toggle del checkbox al hacer clic en la burbuja completa
  const cb = document.querySelector(`.chat-select-check input[data-id="${id}"]`);
  if (cb) {
    cb.checked = !cb.checked;
    onCheckMensaje(cb);
  }
}

function actualizarBarraSeleccion() {
  const n = mensajesSeleccionados.size;
  const count = document.getElementById('chatSelCount');
  if (count) count.textContent = `${n} ${n === 1 ? 'mensaje seleccionado' : 'mensajes seleccionados'}`;

  // El botón "eliminar para todos" solo aparece si el supervisor puede eliminar mensajes de otros
  // (siempre visible para el supervisor)
  const btnTodos = document.getElementById('btnEliminarTodos');
  if (btnTodos) btnTodos.style.display = 'flex'; // siempre visible para supervisor
}

async function eliminarSeleccionados(modo) {
  if (mensajesSeleccionados.size === 0) return;

  const titulo = modo === 'todos'
    ? '¿Eliminar para todos?'
    : '¿Eliminar para ti?';
  const texto = modo === 'todos'
    ? 'Los mensajes seleccionados serán eliminados del chat grupal.'
    : 'Los mensajes se ocultarán solo para ti.';

  const result = await Swal.fire({
    title: titulo,
    text: texto,
    icon: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Sí, eliminar',
    cancelButtonText: 'Cancelar',
    confirmButtonColor: '#ef4444',
    background: document.body.classList.contains('light') ? '#fff' : '#111827',
    color: document.body.classList.contains('light') ? '#0f172a' : '#f1f5f9'
  });

  if (!result.isConfirmed) return;

  const ids = Array.from(mensajesSeleccionados);

  try {
    // Eliminar cada mensaje seleccionado
    await Promise.all(ids.map(id =>
      fetch(`/api/chat/${id}`, { method: 'DELETE' })
    ));
    salirModoSeleccion();
    await cargarMensajesChat();
  } catch(e) {
    console.error('Error eliminando mensajes:', e);
  }
}

// Color único por nombre
function stringToColor(str) {
  const colors = ['#7c5cfc','#06b6d4','#22c55e','#f59e0b','#ef4444','#3b82f6','#ec4899','#8b5cf6'];
  let hash = 0;
  for (let i = 0; i < str.length; i++) hash = str.charCodeAt(i) + ((hash << 5) - hash);
  return colors[Math.abs(hash) % colors.length];
}

// RESIZE del panel
(function() {
  const handle = document.getElementById('chatResizeHandle');
  const panel  = document.getElementById('chatPanel');
  if (!handle || !panel) return;

  let dragging = false;
  let startX = 0;
  let startW = 0;

  handle.addEventListener('mousedown', e => {
    dragging = true;
    startX = e.clientX;
    startW = panel.offsetWidth;
    document.body.style.userSelect = 'none';
    document.body.style.cursor = 'ew-resize';
  });

  document.addEventListener('mousemove', e => {
    if (!dragging) return;
    const delta = startX - e.clientX; // arrastrar hacia la izquierda = más ancho
    const newW = Math.min(Math.max(startW + delta, 300), window.innerWidth * 0.85);
    panel.style.width = newW + 'px';
  });

  document.addEventListener('mouseup', () => {
    if (!dragging) return;
    dragging = false;
    document.body.style.userSelect = '';
    document.body.style.cursor = '';
  });
})();

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function formatearHoraChat(fechaStr) {
    try {
      const d = new Date(fechaStr);
      return d.toLocaleTimeString('es-PE', { hour:'2-digit', minute:'2-digit', hour12:true, timeZone:'America/Lima' });
    } catch(e) { return ''; }
  }

  // Seleccionar imagen
  function seleccionarImagenChat(input) {
    const file = input.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = function(e) {
      chatImagenBase64 = e.target.result; // ya viene como data:image/...;base64,...
      document.getElementById('chatPreviewImg').src = chatImagenBase64;
      document.getElementById('chatPreview').style.display = 'block';
    };
    reader.readAsDataURL(file);
    input.value = '';
  }

  function cancelarImagenChat() {
    chatImagenBase64 = null;
    document.getElementById('chatPreview').style.display = 'none';
    document.getElementById('chatPreviewImg').src = '';
  }

  // Enviar mensaje
  async function enviarMensajeChat() {
    // Si estamos editando, guardar edición en vez de enviar
    const input = document.getElementById('chatInput');
    if (input.dataset.editandoId) {
      const id = input.dataset.editandoId;
      const nuevoTexto = input.value.trim();
      if (!nuevoTexto) return;
      try {
        await fetch(`/api/chat/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ mensaje: nuevoTexto })
        });
        cancelarEdicionChat();
        await cargarMensajesChat();
      } catch(e) {}
      return;
    }
    if (chatEnviando) return;

    if (!supervisorEmail) {
    await loadSupervisor();
    }
    const texto = document.getElementById('chatInput').value.trim();
    if (!texto && !chatImagenBase64) return;

    chatEnviando = true;
    const btn = document.querySelector('.chat-send-btn');
    if (btn) btn.disabled = true;

    let imagen_url = null;

    // Subir imagen si hay
    if (chatImagenBase64) {
      try {
        const res = await fetch('/api/chat/upload', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ imagen: chatImagenBase64 })
        });
        const data = await res.json();
        if (res.ok && data.url) {
          imagen_url = data.url;
        }
      } catch(e) {
        console.error('Error subiendo imagen:', e);
      }
    }

    // Enviar mensaje
    try {
      const res = await fetch('/api/chat/enviar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          mensaje: texto,
          email: supervisorEmail,
          nombre: supervisorNombre,
          rol: '(Supervisor)', 
          imagen_url
        })
      });

      if (res.ok) {
        document.getElementById('chatInput').value = '';
        cancelarImagenChat();
        await cargarMensajesChat();
        const container = document.getElementById('chatMessages');
        if (container) container.scrollTop = container.scrollHeight;
      }
    } catch(e) {
      console.error('Error enviando mensaje:', e);
    }

    chatEnviando = false;
    if (btn) btn.disabled = false;
  }

